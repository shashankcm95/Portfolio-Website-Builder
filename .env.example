# Authentication (Auth.js / NextAuth.js v5)
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_builder

# AI - Anthropic (Claude for analysis + narrative generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# AI - OpenAI (GPT-4o-mini for chatbot + text-embedding-3-small for vectors)
OPENAI_API_KEY=your-openai-api-key

# Cloudflare (Pages deployment)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-with-pages-edit-permission

# Security
ENCRYPTION_KEY=your-aes-256-encryption-key-for-token-storage

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
