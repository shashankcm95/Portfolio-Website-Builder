# Authentication (Auth.js / NextAuth.js v5)
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_builder

# ─── AI Providers ─────────────────────────────────────────────────────────
# Phase 3.5 made the platform LLM keys optional. Set one if you're running
# a hosted instance and want to provide a default for all users. When both
# are unset, every user must configure their own key in Settings → AI
# Provider (BYOK). When both are set, OpenAI is the platform default and
# per-user BYOK still overrides.

# Optional — platform OpenAI key.
# OPENAI_API_KEY=sk-...
# Optional — override the default OpenAI model. Defaults to gpt-4o-mini.
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Optional — platform Anthropic key.
# ANTHROPIC_API_KEY=sk-ant-...
# Optional — override the default Anthropic model. Defaults to claude-haiku-4-5.
# ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5

# Cloudflare (Pages deployment)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-with-pages-edit-permission

# ─── Security ─────────────────────────────────────────────────────────────
# REQUIRED. 32 bytes base64-encoded. Generate with:
#   openssl rand -base64 32
# Used to encrypt user-supplied BYOK keys at rest. Rotating this key
# invalidates every stored BYOK — users will need to re-enter theirs.
ENCRYPTION_KEY=your-32-byte-base64-key

# ─── Object storage (Phase 4.1 — Direct demo upload) ──────────────────────
# All five R2_* vars must be set for the "Upload file" button in the demo
# editor to light up. When any is missing, the feature degrades gracefully
# (button stays disabled with a reason tooltip) and the app boots normally.
#
# Cloudflare R2 is S3-compatible. R2_PUBLIC_BASE_URL is the R2.dev public
# URL (e.g. https://pub-<hash>.r2.dev) or a custom domain mapped to the
# bucket. Raw S3-endpoint URLs require signed auth even for public objects,
# so they don't work as <img src="…">.
#
# Vercel hosted mode has a 4.5 MB serverless body limit — self-hosted /
# Node adapter deployments can use the full 10 MB cap. Presigned direct-
# to-R2 uploads are deferred to a later phase.
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET=your-bucket-name
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
