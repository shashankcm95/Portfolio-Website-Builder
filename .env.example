# =============================================================================
# Portfolio Website Builder — environment configuration
# =============================================================================
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Variables below are grouped into REQUIRED (the app won't boot / core
# features won't work without them) and OPTIONAL (feature-gated — the
# app starts fine; the gated surface just stays dark).
#
# Only variables actually read somewhere under `src/**` or `functions/**`
# are listed here. If you set anything else, it will be ignored.
# =============================================================================


# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Postgres connection string. Local dev uses the docker-compose stack.
# Read in: src/lib/db/index.ts
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_builder

# Auth.js v5 session signing secret. Generate with:
#   openssl rand -base64 32
# Auth.js reads AUTH_SECRET directly from the environment.
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32

# GitHub OAuth app credentials (Auth.js GitHub provider).
# Read in: src/lib/auth/index.ts
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# Master key used to encrypt user-supplied BYOK API keys at rest (Phase R1).
# MUST be exactly 32 bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
# Rotating this key invalidates every stored BYOK — users will need to
# re-enter theirs in Settings → AI Provider.
# Read in: src/lib/crypto/master-key.ts
ENCRYPTION_KEY=your-32-byte-base64-key

# Public origin of the builder itself (no trailing slash). Used to build
# share-link URLs, the analytics beacon endpoint baked into published
# sites, and the cross-origin chatbot iframe src. Published sites that
# self-host their chatbot (Phase 9) don't need the builder's URL, but
# share links, analytics, and the default chatbot iframe do.
# Read in: src/lib/env/app-url.ts (used via getAppUrl())
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── OPTIONAL — AI providers (BYOK fallback) ─────────────────────────────────
# Phase 3.5 made platform LLM keys optional. Set one if you're running a
# hosted instance and want to provide a default for all users. When both
# are unset, every user must configure their own key in Settings → AI
# Provider (BYOK). When set, per-user BYOK still overrides.
# Read in: src/lib/ai/providers/factory.ts, src/lib/ai/openai.ts

# OPENAI_API_KEY=sk-...
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5


# ─── OPTIONAL — Cloudflare (Pages deployment + Workers AI embeddings) ────────
# Required together if you want to publish portfolios to Cloudflare Pages
# or use Workers AI for server-side embeddings. When unset, "Publish"
# stays disabled and the embedding pipeline falls back to the user's
# OpenAI BYOK.
# Read in: src/lib/deployer/cloudflare.ts,
#          src/lib/deployer/cf-waf-rate-limit.ts,
#          src/lib/ai/cf-embed.ts

# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-with-pages-edit-permission


# ─── OPTIONAL — R2 object storage (Phase 4.1 direct demo upload) ─────────────
# All five R2_* vars must be set for the "Upload file" button in the demo
# editor to light up. When any is missing, the feature degrades gracefully
# (button stays disabled with a reason tooltip) and the app boots normally.
#
# R2 is S3-compatible. R2_PUBLIC_BASE_URL is the R2.dev public URL (e.g.
# https://pub-<hash>.r2.dev) or a custom domain mapped to the bucket.
# Raw S3-endpoint URLs require signed auth even for public objects, so
# they don't work as <img src="…">.
#
# Vercel hosted mode has a 4.5 MB serverless body limit — self-hosted /
# Node adapter deployments can use the full 10 MB cap. Presigned direct-
# to-R2 uploads are deferred to a later phase.
# Read in: src/lib/storage/r2.ts

# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET=your-bucket-name
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
