{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      // Phase R5 — the specific rule must come first. swc's tsconfig-paths
      // resolver uses first-match ordering (unlike tsc which tries longest
      // match), so the broader `@/*` would otherwise swallow every
      // `@/templates/…` import and resolve it to `src/templates/…` which
      // doesn't exist. Fixing this order unblocks template snapshot tests
      // and removes the workaround comment in `analytics-offline.test.ts`.
      "@/templates/*": ["./templates/*"],
      "@/*": ["./src/*"]
    },
    "target": "ES2017",
    "forceConsistentCasingInFileNames": true,
    // Phase 9 — Prevent `@cloudflare/workers-types` (used only by
    // `functions/**`) from globally augmenting the Next.js build's type
    // world. Without this, Cloudflare's stricter `fetch`/`Response`
    // declarations leak into `src/**` and break `res.json()` assignment
    // sites that were previously typed as `any`.
    "types": ["node", "jest"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "functions"]
}
